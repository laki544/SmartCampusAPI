<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <servlet>
        <servlet-name>JerseyServlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>

        <!--
            Tell Jersey to scan ALL our packages.
            This is CRITICAL - it must include:
              - resources    (ApiResource, RoomResource, SensorResource, SensorReadingResource)
              - exceptions   (all ExceptionMappers - @Provider classes)
              - filters      (LoggingFilter - @Provider class)
              - config       (AppConfig - the Application subclass)
        -->
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>
                com.smartcampus.resources,
                com.smartcampus.exceptions,
                com.smartcampus.filters,
                com.smartcampus.config
            </param-value>
        </init-param>

        <!-- Enable Jackson JSON auto-discovery -->
        <init-param>
            <param-name>jersey.config.server.provider.classnames</param-name>
            <param-value>org.glassfish.jersey.jackson.JacksonFeature</param-value>
        </init-param>

        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>JerseyServlet</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
